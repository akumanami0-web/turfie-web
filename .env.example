# ── App ─────────────────────────────────────────────────────
# Public base URL — used to build OAuth redirect URIs. Defaults to the
# request origin when unset (fine for local dev).
APP_URL="http://localhost:3000"

# ── Database ────────────────────────────────────────────────
# Dev (default): SQLite, zero setup.
DATABASE_URL="file:./dev.db"
# Production: run `npm run db:postgres` to flip the Prisma provider, then:
# DATABASE_URL="postgresql://turfie:turfie@localhost:5432/turfie?schema=public"

# ── Auth ────────────────────────────────────────────────────
# Secret used to sign session JWTs. Generate: openssl rand -base64 32
AUTH_SECRET="change-me"

# ── Slot locks ──────────────────────────────────────────────
# Optional Redis. When set, slot holds use Redis (SET NX PX); otherwise
# they use the DB lock table. e.g. redis://localhost:6379
REDIS_URL=""

# ── Payments (Razorpay) ─────────────────────────────────────
# When set, checkout takes real payments; otherwise a simulated PSP is used.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# ── Maps ────────────────────────────────────────────────────
# Google Maps JS/Embed API key. When absent, a keyless embed is used.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ── Social sign-in (OAuth) ──────────────────────────────────
# Google — redirect URI: ${APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Apple — redirect URI: ${APP_URL}/api/auth/callback/apple
# APPLE_CLIENT_ID is the Services ID; APPLE_PRIVATE_KEY is the .p8 contents
# (use \n for line breaks if kept on one line).
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
