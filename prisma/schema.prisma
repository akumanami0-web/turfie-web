// Turfie — data model.
// Dev uses SQLite for zero-setup runnability; switch `provider` to
// "postgresql" and point DATABASE_URL at Postgres for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  name         String
  fullName     String
  passwordHash String?
  initials     String   @default("TU")
  city         String   @default("Mumbai")
  level        String   @default("Intermediate")
  role         String   @default("player") // player | operator
  birthday     String?  // yyyy-mm-dd
  gender       String?  // male | female | other | prefer_not
  favSport     String?  // sport id
  photoUrl     String?  // Supabase Storage public URL
  googleId     String?  @unique // stable Google account id (sub) — survives email changes
  phoneVerified Boolean @default(false)
  suspended    Boolean  @default(false)
  walletBalance Int     @default(0) // Turfie wallet balance in ₹
  joinedAt     DateTime @default(now())
  bookings     Booking[]
  favourites   Favourite[]
}

model WalletTxn {
  id        String   @id @default(cuid())
  userId    String
  amount    Int      // signed: + credit, - debit (₹)
  kind      String   // refund | admin_credit | admin_debit | booking
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Otp {
  id        String   @id @default(cuid())
  channel   String   // "email" | "phone"
  target    String   // email address or E.164 phone
  purpose   String   // "signup" | "link_phone" | "change_email" | "verify"
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([channel, target, purpose])
}

model Favourite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  turfId    String
  createdAt DateTime @default(now())

  @@unique([userId, turfId])
  @@index([userId])
}

model Tournament {
  id        String   @id @default(cuid())
  title     String
  sport     String   @default("football")
  format    String   @default("5v5")
  turfId    String?
  area      String?
  address   String?  // custom venue when no listed turf is used
  dateLabel String
  dateKey   String?
  startAt   DateTime? // exact kickoff — used for the 24h join cutoff + countdown
  time      String   @default("TBA")
  slots     Int      @default(16)
  subs      Int      @default(0) // allowed substitutes per team (0-5)
  entryFee  Int      @default(0) // 0 = free to join
  prizePool String?
  status    String   @default("upcoming") // upcoming | live | completed
  blurb     String?
  createdAt DateTime @default(now())
  entries   TournamentEntry[]
}

model TournamentEntry {
  id           String     @id @default(cuid())
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId String
  userId       String
  teamName     String?
  checkedInAt  DateTime?  // set when a vendor scans the battle entry QR
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@index([userId])
}

model Turf {
  id         String   @id
  ownerId    String?  // vendor (User id) who manages this turf
  name       String
  kind       String
  sports     String   // comma-separated sport ids
  primary    String
  area       String
  pin        String
  distLabel  String
  lat        Float
  lng        Float
  rating     Float
  reviews    Int
  price      Int
  surface    String
  formats    String   // comma-separated
  open24     Boolean  @default(false)
  openLabel  String
  openH      Int
  closeH     Int
  fieldCount Int      @default(1)
  unit       String   @default("Pitch")
  blurb      String
  amenities  String   // comma-separated
  spotsLeft  Int
  popular    Boolean  @default(false)
  reviewsList Review[]
  bookings   Booking[]

  @@index([ownerId])
}

model Review {
  id       String @id @default(cuid())
  turf     Turf   @relation(fields: [turfId], references: [id])
  turfId   String
  who      String
  initials String
  rating   Int
  whenLbl  String
  text     String
}

model Booking {
  id           String    @id
  user         User?     @relation(fields: [userId], references: [id])
  userId       String?
  turf         Turf      @relation(fields: [turfId], references: [id])
  turfId       String
  field        String    @default("A")
  unit         String    @default("Pitch")
  dateKey      String?   // ISO yyyy-mm-dd
  dateLabel    String
  time         String
  startHour    Int?
  duration     String    @default("1 hr")
  durationHrs  Int       @default(1)
  players      String    @default("1/10")
  status       String    @default("upcoming") // upcoming | completed | cancelled
  price        Int
  sport        String
  split        Boolean   @default(false)
  kickoffAt    DateTime?
  contactName  String?
  contactPhone String?
  contactEmail String?
  refundMethod String?
  refundPct    Int?
  refundAmount Int?
  cancelledAt  DateTime?
  rescheduledAt DateTime? // last time this booking was moved
  prevDateLabel String?   // the date label it was moved from
  prevTime      String?   // the time it was moved from
  checkedInAt  DateTime? // set when a vendor scans the entry QR
  walletUsed   Int       @default(0) // ₹ paid from Turfie wallet
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([turfId, field, dateKey])
}

// 10-minute slot holds. In production this is a Redis key
// `lock:{turfId}:{field}:{date}:{hour}` with PX 600000; here it is a
// DB row with expiresAt and a uniqueness constraint per slot.
model SlotLock {
  id        String   @id @default(cuid())
  turfId    String
  field     String
  dateKey   String
  hour      Int
  owner     String   // session id or user id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([turfId, field, dateKey, hour])
  @@index([expiresAt])
}

// Per-owner monthly reschedule allowance (5 free, then a fee).
model RescheduleUsage {
  id    String @id @default(cuid())
  owner String
  month String // yyyy-mm
  count Int    @default(0)

  @@unique([owner, month])
}
